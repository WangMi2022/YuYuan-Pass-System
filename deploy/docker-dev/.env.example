PROJECT_NAME=gin-vue-admin-dev
SERVER_IMAGE=gin-vue-admin-server:dev
WEB_IMAGE=gin-vue-admin-web:dev
SERVER_CONTAINER=gva-server-dev
WEB_CONTAINER=gva-web-dev
SERVER_PORT=8888
WEB_PORT=8080

GVA_DB_TYPE=pgsql
GVA_PG_HOST=127.0.0.1
GVA_PG_PORT=5432
GVA_PG_USER=postgres
GVA_PG_PASSWORD=change-me
GVA_PG_DB=gva
GVA_PG_TEMPLATE=template0
GVA_ADMIN_PASSWORD=123456

GVA_USE_REDIS=true
GVA_REDIS_ADDR=127.0.0.1:6379
GVA_REDIS_PASSWORD=change-me
GVA_REDIS_DB=0

# RustFS 控制台通常为 :9001，应用必须连接 S3 API（通常为 :9000）
GVA_RUSTFS_ENDPOINT=127.0.0.1:9000
GVA_RUSTFS_CONSOLE=http://127.0.0.1:9001
GVA_RUSTFS_ACCESS_KEY=change-me
GVA_RUSTFS_SECRET_KEY=change-me
GVA_RUSTFS_BUCKET=gva-assets
GVA_RUSTFS_BASE_PATH=assets
GVA_RUSTFS_USE_SSL=false
